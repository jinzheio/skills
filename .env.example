# Copy this file to .env if your runner loads environment variables.
# Keep real values out of git.

# GitHub owner used when creating repositories.
# Format: GitHub user or organization slug, not a URL.
# Examples: acme, my-org
GITHUB_OWNER=

# Vercel team or personal scope used by `vercel --scope`.
# Format: Vercel slug shown in the dashboard/team URL, not a display name.
# Examples: acme, my-team
VERCEL_SCOPE=

# Optional path to a JSON map from domain to repo/integration metadata.
# Format: absolute or repo-relative file path.
# Example: ./config/site-integrations.json
SITE_INTEGRATIONS_CONFIG=

# Optional Microsoft Clarity fallback for index-onboarding.
# Used only when SITE_INTEGRATIONS_CONFIG is missing or lacks Clarity for the target domain.
# CLARITY_ID: existing Clarity project id.
# CLARITY_TOKEN: project-level Data Export API token.
CLARITY_ID=
CLARITY_TOKEN=

# Cloudflare API token for DNS edits and optional proxy/TLS/email routing changes.
# Recommended scope: limited token for the target zone with DNS edit permission.
CLOUDFLARE_API_TOKEN=

# Cloudflare account id for account-scoped operations.
# Format: Cloudflare account id string from the dashboard URL/API.
CLOUDFLARE_ACCOUNT_ID=

# Spaceship registrar API credentials for nameserver updates.
# Needed only when the domain is registered at Spaceship and API automation is used.
SPACESHIP_API_KEY=
SPACESHIP_API_SECRET=

# Umami-compatible analytics setup.
# UMAMI_BASE_URL: analytics API origin, for example https://analytics.example.com/api
# UMAMI_SCRIPT_URL: script URL served by the analytics server, for example https://analytics.example.com/script.js
# UMAMI_API_KEY: optional API key for Umami Cloud or compatible providers that support API-key auth.
# Self-hosted Umami uses admin login at $UMAMI_BASE_URL/auth/login to obtain a Bearer token.
UMAMI_BASE_URL=
UMAMI_API_KEY=
UMAMI_SCRIPT_URL=
UMAMI_ADMIN_USERNAME=
UMAMI_ADMIN_PASSWORD=

# Google Search Console / Site Verification auth.
# Preferred local setup for a user-owned site:
#   gcloud auth application-default login
# If you use a credential file instead, set GOOGLE_APPLICATION_CREDENTIALS to its path.
# Format: absolute or repo-relative path to a Google ADC JSON file.
# Example: /secure/path/google-adc.json
GOOGLE_APPLICATION_CREDENTIALS=

# Optional Google Cloud project used for quota/billing headers by some Google clients.
# Format: project id, not project number.
# Example: my-gcp-project
GOOGLE_CLOUD_PROJECT=

# Bing Webmaster Tools API key.
# Used to add/verify sites and submit feeds/URLs when API automation is available.
BING_WEBMASTER_API_KEY=

# IndexNow override.
# Usually leave this blank: add-indexnow generates a fresh host-scoped key.
# Set only if reusing an existing key for the same host.
INDEXNOW_KEY=
