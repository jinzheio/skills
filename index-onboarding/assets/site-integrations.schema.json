{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["domains"],
  "properties": {
    "domains": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "repo_dir": {
            "type": "string",
            "description": "Absolute path to the domain's source repository."
          },
          "clarity": {
            "type": "object",
            "properties": {
              "project_id": {
                "type": "string"
              },
              "project_name": {
                "type": "string"
              },
              "token": {
                "type": "string",
                "description": "Project-level Clarity Data Export API token."
              }
            },
            "required": ["project_id", "token"],
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
